---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Tangent",
  description = "Brain dumps from a guy who should be sleeping. Tech, games, dad life, zero filter.",
  ogImage = "https://newsletter.chiubaca.com/og.png",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site || "https://newsletter.chiubaca.com").toString();

const statusMessages = [
  "STATUS: BARELY FUNCTIONING",
  "CALVIN: PROBABLY AWAKE",
  "SLEEP: OPTIONAL",
  "COFFEE #4 AND COUNTING",
  "DEPLOYED AT 3:47AM",
  "TOUCHED GRASS: NOT RECENTLY",
  "BUG COUNT: ACCEPTABLE LOSSES",
];
const status = statusMessages[Math.floor(Math.random() * statusMessages.length)];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#04060a" />

    {/* Favicon — simple T mark */}
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' x='50%25' text-anchor='middle' font-family='monospace' font-size='80' fill='%23c9841a'%3ET%3C/text%3E%3C/svg%3E" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@chiubaca" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>
  </head>

  <body>
    {/* Status bar — random on each load */}
    <div class="status-bar">
      <div class="max-w-3xl mx-auto flex items-center justify-between">
        <span>{status}</span>
        <span class="hidden sm:inline">BUILD: {new Date().toISOString().slice(0, 10)}</span>
        <span>NO CAP</span>
      </div>
    </div>

    <div class="min-h-screen flex flex-col">
      {/* Header */}
      <header class="border-b" style="border-color: var(--border-subtle);">
        <div class="max-w-3xl mx-auto px-6 py-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 sm:gap-0">
          <a href="/" class="group inline-flex items-center gap-2 glitch-hover">
            <span
              class="text-3xl sm:text-4xl tracking-tight"
              style="font-family: var(--font-display); line-height: 0.9;"
            >
              TANGENT
            </span>
          </a>

          <nav class="flex items-center gap-5 sm:gap-6">
            <a
              href="/"
              class="nav-link text-[11px] sm:text-xs font-mono uppercase tracking-widest opacity-60 hover:opacity-100"
              style="color: var(--text-secondary);"
            >
              The Lore
            </a>
            <a
              href="https://chiubaca.com"
              target="_blank"
              rel="noopener noreferrer"
              class="nav-link text-[11px] sm:text-xs font-mono uppercase tracking-widest opacity-60 hover:opacity-100"
              style="color: var(--text-secondary);"
            >
              chiubaca.com
            </a>
          </nav>
        </div>
      </header>

      {/* Decorative line */}
      <div class="divider-gradient"></div>

      {/* Main */}
      <main class="flex-1">
        <slot />
      </main>

      {/* Footer */}
      <footer class="border-t" style="border-color: var(--border-subtle);">
        <div class="max-w-3xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-xs font-mono opacity-40" style="color: var(--text-muted);">
            BUILT WITH ☕ AND DELUSION. &copy; ALEX CHIU. CALVIN'S DAD.
          </p>
          <div class="flex items-center gap-4">
            <a
              href="https://github.com/chiubaca"
              target="_blank"
              rel="noopener noreferrer"
              class="nav-link text-xs font-mono opacity-40 hover:opacity-80"
              style="color: var(--text-muted);"
            >
              GitHub
            </a>
            <a
              href="https://bsky.app/profile/chiubaca.com"
              target="_blank"
              rel="noopener noreferrer"
              class="nav-link text-xs font-mono opacity-40 hover:opacity-80"
              style="color: var(--text-muted);"
            >
              Bluesky
            </a>
            <a
              href="https://twitter.com/chiubaca"
              target="_blank"
              rel="noopener noreferrer"
              class="nav-link text-xs font-mono opacity-40 hover:opacity-80"
              style="color: var(--text-muted);"
            >
              X
            </a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
