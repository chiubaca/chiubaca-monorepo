---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const newsletters = await getCollection("newsletter");
const liveNewsletters = newsletters
  .filter((n) => n.data.status === "live")
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latest = liveNewsletters[0];
const rest = liveNewsletters.slice(1);
---

<BaseLayout
  title="Tangent — Archive"
  description="Off-script notes on tech, games, and whatever else. By Alex Chiu."
>
  <div class="hero-glow">
    <div class="max-w-3xl mx-auto px-6 pt-16 pb-12">
      {/* Hero */}
      <div class="mb-14">
        <p
          class="text-xs font-mono uppercase tracking-[0.3em] mb-4 animate-fade-up"
          style="color: var(--accent-amber);"
        >
          By Alex Chiu
        </p>
        <h1
          class="text-5xl sm:text-6xl mb-5 animate-fade-up delay-1"
          style="font-family: var(--font-serif); line-height: 1.05;"
        >
          Tangent
        </h1>
        <p
          class="text-base max-w-md animate-fade-up delay-2"
          style="color: var(--text-muted);"
        >
          Off-script notes on tech, games, and whatever else.
        </p>
      </div>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-6 pb-20">
    {/* Issue count bar */}
    <div
      class="flex items-center justify-between mb-10 pb-4 border-b animate-fade-up delay-3"
      style="border-color: var(--border-subtle);"
    >
      <span class="text-xs font-mono uppercase tracking-widest" style="color: var(--text-dim);">
        {liveNewsletters.length} issues
      </span>
      <span class="text-xs font-mono" style="color: var(--text-dim);">
        Newest first
      </span>
    </div>

    {/* Featured latest issue */}
    {latest && (
      <a
        href={`/${latest.id}/`}
        class="group block mb-10 p-6 sm:p-8 rounded-xl border transition-all duration-300 animate-fade-up delay-3"
        style="
          border-color: var(--border-amber);
          background: linear-gradient(135deg, var(--bg-raised) 0%, var(--bg-surface) 100%);
          box-shadow: 0 0 30px rgba(201, 132, 26, 0.06);
        "
      >
        <div class="flex items-center gap-3 mb-4">
          <span
            class="font-mono text-sm font-bold"
            style="color: var(--accent-amber);"
          >
            Issue #{latest.data.issue}
          </span>
          <span class="badge-latest">Latest</span>
          <span class="text-xs font-mono ml-auto" style="color: var(--text-dim);">
            {latest.data.pubDate.toLocaleDateString("en-GB", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })}
          </span>
        </div>
        <h2
          class="text-2xl sm:text-3xl mb-3 group-hover:underline transition-all"
          style="font-family: var(--font-serif); color: var(--text-primary);"
        >
          {latest.data.title}
        </h2>
        {latest.data.description && (
          <p class="text-sm sm:text-base" style="color: var(--text-muted);">
            {latest.data.description}
          </p>
        )}
        <div class="mt-5 flex items-center gap-2 text-xs font-mono" style="color: var(--accent-amber);">
          <span>Read issue</span>
          <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
        </div>
      </a>
    )}

    {/* Archive list */}
    <div class="space-y-0">
      {
        rest.map((n, idx) => {
          const delayClass = `delay-${Math.min(idx + 4, 8)}`;
          return (
            <a
              href={`/${n.id}/`}
              class={`group archive-row py-6 px-4 -mx-4 border-b animate-fade-up ${delayClass}`}
              style="border-color: var(--border-subtle);"
            >
              <div class="flex items-start gap-5 sm:gap-6">
                {/* Issue number */}
                <div class="flex-shrink-0 w-14 sm:w-16 text-right pt-1">
                  <span
                    class="font-mono text-lg sm:text-xl font-bold opacity-30 group-hover:opacity-60 transition-opacity"
                    style="color: var(--accent-amber);"
                  >
                    {String(n.data.issue).padStart(2, "0")}
                  </span>
                </div>

                {/* Content */}
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 mb-1.5">
                    <span
                      class="text-xs font-mono"
                      style="color: var(--text-dim);"
                    >
                      {n.data.pubDate.toLocaleDateString("en-GB", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })}
                    </span>
                  </div>

                  <h3
                    class="text-lg sm:text-xl mb-1.5 group-hover:underline transition-all"
                    style="font-family: var(--font-serif); color: var(--text-primary);"
                  >
                    {n.data.title}
                  </h3>

                  {n.data.description && (
                    <p
                      class="text-sm line-clamp-2"
                      style="color: var(--text-muted);"
                    >
                      {n.data.description}
                    </p>
                  )}
                </div>

                {/* Arrow */}
                <div class="flex-shrink-0 pt-6 opacity-0 group-hover:opacity-100 transition-opacity">
                  <span style="color: var(--accent-amber);">→</span>
                </div>
              </div>
            </a>
          );
        })
      }
    </div>

    {liveNewsletters.length === 0 && (
      <div class="text-center py-20 animate-fade-up">
        <p style="color: var(--text-dim);">Nothing here yet.</p>
      </div>
    )}
  </div>
</BaseLayout>
