---
layout: false
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Unsubscribe — Tangent</title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' x='50%25' text-anchor='middle' font-family='monospace' font-size='80' fill='%23c9841a'%3ET%3C/text%3E%3C/svg%3E">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@400;500;700&display=swap');
    * { box-sizing: border-box; }
    body {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      background: #04060a;
      color: #e2e8f0;
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .container {
      width: 100%;
      max-width: 440px;
      text-align: center;
    }
    .brand { margin-bottom: 32px; }
    .brand h1 {
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: 56px;
      color: #c9841a;
      margin: 0 0 8px 0;
      line-height: 1;
    }
    .brand p { color: #64748b; font-size: 13px; margin: 0; }
    .card {
      background: #0a0f1a;
      border: 1px solid rgba(148,163,184,0.08);
      padding: 40px 32px;
      margin-bottom: 24px;
    }
    .card h2 {
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: 28px;
      color: #e2e8f0;
      margin: 0 0 12px 0;
    }
    .card p {
      color: #94a3b8;
      font-size: 13px;
      line-height: 1.6;
      margin: 0 0 24px 0;
    }
    .btn {
      padding: 14px 32px;
      background: transparent;
      color: #c92a2a;
      font-family: 'JetBrains Mono', monospace;
      font-weight: 700;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border: 1px solid rgba(201,42,42,0.3);
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn:hover {
      background: rgba(201,42,42,0.1);
      border-color: rgba(201,42,42,0.6);
    }
    .btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }
    .back-link {
      font-size: 12px;
      color: #475569;
      text-decoration: none;
    }
    .back-link:hover { color: #c9841a; }
  </style>
</head>
<body>
  <div class="container">
    <div class="brand">
      <h1>TANGENT</h1>
      <p>Brain dumps from a guy who should be sleeping</p>
    </div>

    <div class="card">
      <h2>LEAVE THE CULT?</h2>
      <p id="status">Loading…</p>
      <button id="btn" class="btn" style="display:none;">UNSUBSCRIBE</button>
    </div>

    <a href="/" class="back-link">← back to all issues</a>
  </div>

  <script>
    const token = new URLSearchParams(location.search).get('token');
    const status = document.getElementById('status');
    const btn = document.getElementById('btn');

    if (!token) {
      status.textContent = 'That link looks broken. No token found.';
    } else {
      status.textContent = 'You\'re about to unsubscribe from Tangent. No hard feelings.';
      btn.style.display = 'inline-block';

      btn.addEventListener('click', () => {
        btn.disabled = true;
        btn.textContent = 'PROCESSING…';

        fetch(`/api/unsubscribe?token=${encodeURIComponent(token)}`, { method: 'POST' })
          .then(r => r.json())
          .then(data => {
            status.textContent = data.success
              ? 'You\'re unsubscribed. You\'ll receive one last email confirming this. Take care.'
              : (data.error || 'Something went wrong. Try again?');
            btn.style.display = 'none';
          })
          .catch(() => {
            status.textContent = 'Network error. Try again?';
            btn.disabled = false;
            btn.textContent = 'UNSUBSCRIBE';
          });
      });
    }
  </script>
</body>
</html>
