---
layout: false
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Confirmed — Tangent</title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' x='50%25' text-anchor='middle' font-family='monospace' font-size='80' fill='%23c9841a'%3ET%3C/text%3E%3C/svg%3E">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@400;500;700&display=swap');

    * { box-sizing: border-box; }
    body {
      font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, monospace;
      background: #04060a;
      color: #e2e8f0;
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .container {
      width: 100%;
      max-width: 440px;
      text-align: center;
    }
    .brand {
      margin-bottom: 32px;
    }
    .brand h1 {
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: 56px;
      color: #c9841a;
      margin: 0 0 8px 0;
      line-height: 1;
    }
    .brand p {
      color: #64748b;
      font-size: 13px;
      margin: 0;
    }
    .card {
      background: #0a0f1a;
      border: 1px solid rgba(148,163,184,0.08);
      padding: 40px 32px;
      margin-bottom: 24px;
    }
    .check {
      font-size: 48px;
      margin-bottom: 16px;
      color: #097c48;
    }
    .card h2 {
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: 28px;
      color: #e2e8f0;
      margin: 0 0 12px 0;
    }
    .card p {
      color: #94a3b8;
      font-size: 13px;
      line-height: 1.6;
      margin: 0;
    }
    .back-link {
      font-size: 12px;
      color: #475569;
      text-decoration: none;
    }
    .back-link:hover { color: #c9841a; }
    .error { color: #c92a2a; }
  </style>
</head>
<body>
  <div class="container">
    <div class="brand">
      <h1>TANGENT</h1>
      <p>Brain dumps from a guy who should be sleeping</p>
    </div>

    <div class="card">
      <div class="check" id="check">⏳</div>
      <h2 id="title">Confirming…</h2>
      <p id="message">One sec.</p>
    </div>

    <a href="/" class="back-link">← back to all issues</a>
  </div>

  <script>
    const token = new URLSearchParams(location.search).get('token');
    const check = document.getElementById('check');
    const title = document.getElementById('title');
    const message = document.getElementById('message');

    if (!token) {
      check.textContent = '⚠️';
      title.textContent = 'Missing Token';
      message.textContent = 'That confirmation link looks broken. Try subscribing again.';
    } else {
      fetch(`/api/confirm?token=${encodeURIComponent(token)}`)
        .then(r => r.json())
        .then(data => {
          if (data.success) {
            check.textContent = '✅';
            title.textContent = 'You\'re In';
            message.textContent = data.message === 'Already confirmed'
              ? 'You were already confirmed. Nothing to do here.'
              : 'You\'ll get Tangent drops as soon as they ship. No spam, just words.';
          } else {
            check.textContent = '⚠️';
            title.textContent = 'Something Went Wrong';
            message.textContent = data.error || 'Try the link again or re-subscribe.';
            check.classList.add('error');
          }
        })
        .catch(() => {
          check.textContent = '⚠️';
          title.textContent = 'Network Error';
          message.textContent = 'Check your connection and try again.';
          check.classList.add('error');
        });
    }
  </script>
</body>
</html>
