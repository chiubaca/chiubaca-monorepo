---
import { getEntry, render } from "astro:content";
import { getCollection } from "astro:content";
import AnimtedBlinkingTitle from "../components/AnimatedBlinkingTitle.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const blogs = await getCollection("permanent-notes");
const liveBlogs = blogs
  .filter((blog) => blog.data.status === "live")
  .sort((a, b) => b.data.publish_date.valueOf() - a.data.publish_date.valueOf())
  .slice(0, 5);

const fleetingNotes = await getCollection("fleeting-notes");
const latestFleetingNote = fleetingNotes.sort(
  (a, b) => b.data.publish_date.valueOf() - a.data.publish_date.valueOf()
)[0];
const latestFleetingNoteEntry = await getEntry(
  "fleeting-notes",
  latestFleetingNote.id
);
const { Content: LatestFleetingNoteContent } = await render(
  latestFleetingNoteEntry
);
---

<BaseLayout
  title="home | chiubaca.com"
  description="A digital garden of ramblings by Alex Chiu. Built with ☕ and delusion."
>
  <main>
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <nav class="py-12">
        <AnimtedBlinkingTitle />
      </nav>

      <section class="latest-blogs space-y-6">
        <h1
          class="text-3xl sm:text-4xl tracking-tight"
          style="font-family: var(--font-display); line-height: 1;"
        >
          ✏️ Latest Writings
        </h1>
        <p class="text-secondary pb-8 opacity-60">
          Long form blogs, essays, musings. The stuff I actually finished.
        </p>

        <div>
          {
            liveBlogs.map((blog) => {
              return (
                <div class="blog-post-summary mb-6">
                  <p class="text-xs font-mono opacity-50 uppercase tracking-wider">
                    {blog.data.publish_date
                      .toLocaleDateString("en-GB", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })
                      .toString()
                      .toUpperCase()}
                  </p>
                  <a
                    href={`/${blog.id}/`}
                    class="hover:underline font-bold uppercase tracking-tight"
                    style="font-family: var(--font-display); font-size: 1.35rem; line-height: 1.15;"
                    transition:name="blog-title"
                  >
                    {blog.data.title}
                  </a>
                </div>
              );
            })
          }
        </div>

        <a
          href={`/blogs/`}
          class="font-bold btn btn-info btn-xs uppercase tracking-tight"
        >
          View all blogs <span class="text-2xl">→</span>
        </a>
      </section>

      <hr class="my-12 border-neutral-700" />
    </div>

    <section>
      <div class="max-w-2xl mx-auto px-4 sm:px-6 space-y-6">
        <h1
          class="text-3xl sm:text-4xl tracking-tight"
          style="font-family: var(--font-display); line-height: 1;"
        >
          📝 Latest Note
        </h1>
        <p class="text-secondary opacity-60">
          Latest rambling posted on {
            latestFleetingNote.data.publish_date.toLocaleDateString("en-GB", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </p>
        <div
          class="mb-8 mt-4 flex flex-wrap items-center gap-2 font-mono text-xs"
        >
          {
            latestFleetingNoteEntry.data.tags.map((tag) => (
              <a
                href={`/tags#${tag}`}
                class="hover:link border-gray-300 text-gray-600 before:content-['#'] dark:border-gray-600 dark:text-gray-400 not-prose uppercase tracking-tight"
              >
                {tag}
              </a>
            ))
          }
        </div>
      </div>

      <div x-data="{ open: false }">
        <article
          class="min-h-20 prose mx-auto overflow-hidden px-4 sm:px-6 sm:!max-w-2xl transition-[max-height] duration-300 ease-in-out"
          x-bind:class="{
            'max-h-[100rem]': open,
            'max-h-96 scroll-fade-bottom': !open 
          }"
        >
          <LatestFleetingNoteContent />
        </article>
        <div class="flex justify-center mt-4">
          <button
            class="btn btn-sm btn-ghost uppercase tracking-tight text-xs"
            @click="open = !open"
            x-text="open ? 'collapse ↑' : 'show more ↓'"></button>
        </div>
      </div>

      <div class="max-w-2xl mx-auto px-4 sm:px-6 pb-12">
        <a
          href={`/fleeting-notes/`}
          class="mt-8 font-bold btn btn-info btn-xs uppercase tracking-tight"
        >
          View all notes <span class="text-2xl">→</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .scroll-fade-bottom {
    -webkit-mask-image: linear-gradient(
      to bottom,
      black calc(100% - 5rem),
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      black calc(100% - 5rem),
      transparent 100%
    );
  }
</style>
