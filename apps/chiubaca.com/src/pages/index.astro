---
import { getEntry, render } from "astro:content";
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import TerminalDivider from "../components/TerminalDivider.astro";

const blogs = await getCollection("permanent-notes");
const liveBlogs = blogs
  .filter((blog) => blog.data.status === "live")
  .sort((a, b) => b.data.publish_date.valueOf() - a.data.publish_date.valueOf())
  .slice(0, 5);

const fleetingNotes = await getCollection("fleeting-notes");
const latestFleetingNote = fleetingNotes.sort(
  (a, b) => b.data.publish_date.valueOf() - a.data.publish_date.valueOf()
)[0];
const latestFleetingNoteEntry = await getEntry(
  "fleeting-notes",
  latestFleetingNote.id
);
const { Content: LatestFleetingNoteContent } = await render(
  latestFleetingNoteEntry
);
---

<BaseLayout
  title="home | chiubaca.com"
  description="A digital garden of ramblings by Alex Chiu. Built with ☕ and delusion."
  breadcrumbs={[]}
>
  <main>
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      {/* Logo back in body */}
      <nav class="py-12">
        <div class="group logo-container flex items-center font-mono cursor-pointer decoration-2 glitch-hover">
          <span class="blink pb-[2px] text-[var(--accent-blue)]">&#x258C;</span>
          <span class="transition-colors uppercase font-bold tracking-tight text-xl sm:text-2xl">chiubaca.com</span>
        </div>
      </nav>

      <section class="latest-blogs space-y-6">
        <h1
          class="text-3xl sm:text-4xl tracking-tight"
          style="font-family: var(--font-display); line-height: 1;"
        >
          <span class="comment-prefix">//</span> Latest Writings
        </h1>
        <p class="pb-8 opacity-60" style="color: var(--text-muted);">
          Long form blogs, essays, musings. The stuff I actually finished.
        </p>

        <div>
          {
            liveBlogs.map((blog) => {
              return (
                <a
                  href={`/${blog.id}/`}
                  class="group blog-row block mb-6 py-3 px-3 -mx-3"
                >
                  <p class="text-xs font-mono opacity-50 uppercase tracking-wider mb-1">
                    {blog.data.publish_date
                      .toLocaleDateString("en-GB", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })
                      .toString()
                      .toUpperCase()}
                  </p>
                  <h3
                    class="font-bold uppercase tracking-tight transition-all group-hover:translate-x-1"
                    style="font-family: var(--font-display); font-size: 1.35rem; line-height: 1.15; color: var(--text-primary);"
                    transition:name="blog-title"
                  >
                    {blog.data.title}
                  </h3>
                </a>
              );
            })
          }
        </div>

        <a
          href={`/blogs/`}
          class="group inline-flex items-center gap-2 text-xs font-mono uppercase tracking-widest transition-colors"
          style="color: var(--text-dim);"
        >
          <span class="group-hover:text-amber-500 transition-colors">View all blogs</span>
          <span class="transition-transform group-hover:translate-x-1" style="color: var(--text-muted);">→</span>
        </a>
      </section>

      <TerminalDivider class="my-12" />
    </div>

    <section>
      <div class="max-w-2xl mx-auto px-4 sm:px-6 space-y-6">
        <h1
          class="text-3xl sm:text-4xl tracking-tight"
          style="font-family: var(--font-display); line-height: 1;"
        >
          <span class="comment-prefix">//</span> Latest Note
        </h1>
        <p class="opacity-60" style="color: var(--text-muted);">
          Latest rambling posted on {
            latestFleetingNote.data.publish_date.toLocaleDateString("en-GB", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </p>
        <div
          class="mb-8 mt-4 flex flex-wrap items-center gap-2 font-mono text-xs"
        >
          {
            latestFleetingNoteEntry.data.tags.map((tag) => (
              <a
                href={`/tags#${tag}`}
                class="px-2 py-1 border text-xs uppercase tracking-tight transition-colors hover:border-amber-500 hover:text-amber-400"
                style="border-color: rgba(201, 132, 26, 0.25); color: var(--text-muted);"
              >
                #{tag}
              </a>
            ))
          }
        </div>
      </div>

      <div x-data="{ open: false }">
        <article
          class="min-h-20 prose mx-auto overflow-hidden px-4 sm:px-6 sm:!max-w-2xl transition-[max-height] duration-300 ease-in-out"
          x-bind:class="{
            'max-h-[100rem]': open,
            'max-h-96 scroll-fade-bottom': !open 
          }"
        >
          <LatestFleetingNoteContent />
        </article>
        <div class="flex justify-center mt-4">
          <button
            class="text-xs font-mono uppercase tracking-widest transition-colors hover:text-amber-500"
            style="color: var(--text-dim); background: transparent; border: none; cursor: pointer;"
            @click="open = !open"
            x-text="open ? 'collapse ↑' : 'show more ↓'"></button>
        </div>
      </div>

      <div class="max-w-2xl mx-auto px-4 sm:px-6 pb-12">
        <a
          href={`/fleeting-notes/`}
          class="mt-8 group inline-flex items-center gap-2 text-xs font-mono uppercase tracking-widest transition-colors"
          style="color: var(--text-dim);"
        >
          <span class="group-hover:text-amber-500 transition-colors">View all notes</span>
          <span class="transition-transform group-hover:translate-x-1" style="color: var(--text-muted);">→</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .blink {
    animation: blinker 1s linear infinite;
  }

  @keyframes blinker {
    100% {
      opacity: 0;
    }
  }

  .scroll-fade-bottom {
    -webkit-mask-image: linear-gradient(
      to bottom,
      black calc(100% - 5rem),
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      black calc(100% - 5rem),
      transparent 100%
    );
  }

  .blog-row {
    border-left: 2px solid transparent;
    transition: background-color 0.15s ease, border-color 0.15s ease, padding-left 0.15s ease;
  }

  .blog-row:hover {
    background-color: rgba(121, 192, 255, 0.03);
    border-left-color: var(--accent-blue);
    padding-left: 1rem;
  }
</style>
