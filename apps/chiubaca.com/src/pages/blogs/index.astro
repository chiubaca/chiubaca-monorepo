---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const blogs = await getCollection("permanent-notes");
const liveBlogs = blogs
  .filter((blog) => blog.data.status === "live")
  .sort(
    (a, b) => b.data.publish_date.valueOf() - a.data.publish_date.valueOf()
  );
---

<BaseLayout
  title="blogs | chiubaca.com"
  description="Longer words, essays, musings."
  breadcrumbs={[
    {
      href: "/blogs",
      label: "blogs",
    },
  ]}
>
  <section class="py-12 max-w-2xl mx-auto px-4 sm:px-6 space-y-6">
    <h1
      class="text-3xl sm:text-4xl tracking-tight"
      style="font-family: var(--font-display); line-height: 1;"
    >
      <span class="comment-prefix">//</span> All Writings
    </h1>
    <p class="pb-8 opacity-60" style="color: var(--text-muted);">
      Long form blogs, essays, musings.
    </p>

    <div>
      {
        liveBlogs.map((blog) => {
          return (
            <a
              href={`/${blog.id}/`}
              class="group blog-row block mb-6 py-3 px-3 -mx-3"
            >
              <p class="text-xs font-mono opacity-50 uppercase tracking-wider mb-1">
                {blog.data.publish_date
                  .toLocaleDateString("en-GB", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })
                  .toString()
                  .toUpperCase()}
              </p>
              <h3
                class="font-bold uppercase tracking-tight transition-all group-hover:translate-x-1"
                style="font-family: var(--font-display); font-size: 1.35rem; line-height: 1.15; color: var(--text-primary);"
              >
                {blog.data.title}
              </h3>
            </a>
          );
        })
      }
    </div>

    {liveBlogs.length === 0 && <p style="color: var(--text-muted);">No blogs published yet. Check back soon!</p>}
  </section>
</BaseLayout>

<style>
  .blog-row {
    border-left: 2px solid transparent;
    transition: background-color 0.15s ease, border-color 0.15s ease, padding-left 0.15s ease;
  }

  .blog-row:hover {
    background-color: rgba(121, 192, 255, 0.03);
    border-left-color: var(--accent-blue);
    padding-left: 1rem;
  }
</style>
