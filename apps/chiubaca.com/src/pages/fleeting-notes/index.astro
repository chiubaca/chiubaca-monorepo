---
import { getEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const fleetingNotesCollection = await getCollection("fleeting-notes");
const fleetingNotes = fleetingNotesCollection.sort(
  (a, b) => b.data.publish_date.valueOf() - a.data.publish_date.valueOf()
);
---

<BaseLayout
  title="fleeting-notes | chiubaca.com"
  description="Unorganised fleeting thoughts, ideas, and notes."
  breadcrumbs={[
    {
      href: "/fleeting-notes",
      label: "fleeting-notes",
    },
  ]}
>
  <div class="py-12 overflow-y-hidden">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 space-y-6">
      <h1
        class="text-3xl sm:text-4xl tracking-tight"
        style="font-family: var(--font-display); line-height: 1;"
      >
        <span class="comment-prefix">//</span> All Notes
      </h1>
      <p class="pb-8 opacity-60" style="color: var(--text-muted);">
        Unorganised fleeting thoughts, ideas, and notes.
      </p>
    </div>

    {
      fleetingNotes.map(async (note) => {
        const entry = await getEntry("fleeting-notes", note.id);

        const { Content } = await render(entry);

        return (
          <section class="max-w-2xl mx-auto px-4 sm:px-6 space-y-6">
            <a href={`/fleeting-notes/${note.id}`} class="group block">
              <h2
                class="text-xl sm:text-2xl tracking-tight transition-colors group-hover:text-amber-500"
                style="font-family: var(--font-display); line-height: 1.1; color: var(--text-primary);"
              >
                {note.id.replaceAll("-", " ")}
              </h2>
            </a>
            <div class="my-3 flex flex-wrap items-center gap-2 font-mono text-xs">
              {entry.data.tags.map((tag) => (
                <a
                href={`/tags#${tag}`}
                class="px-2 py-1 border text-xs uppercase tracking-tight transition-colors hover:border-amber-500 hover:text-amber-400"
                style="border-color: rgba(201, 132, 26, 0.25); color: var(--text-muted);"
                >
                  #{tag}
                </a>
              ))}
            </div>

            <div class="prose prose-a:break-all">
              <Content />
            </div>

            <div class="divider-gradient my-10"></div>
          </section>
        );
      })
    }
  </div>
</BaseLayout>
