---
import { cvData } from "../data/cv";

interface Props {
  data?: typeof cvData;
}

const data = Astro.props.data || cvData;
---

<!-- Header -->
<header class="border-b border-gray-700 pb-6 mb-8">
  <h1 class="text-4xl font-bold text-white mb-2">{data.header.name}</h1>
  <p class="text-gray-400 max-w-xl">{data.header.summary}</p>
</header>

<!-- Content Grid -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <!-- Main Content -->
  <div class="lg:col-span-2 space-y-8">
    <!-- Experience -->
    <section>
      <h2 class="text-sm font-bold text-blue-500 uppercase tracking-wider mb-6">Experience</h2>
      
      {data.experience.map((job) => (
        <div class="mb-6">
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-1 mb-2">
            <h3 class="text-lg font-bold text-white">{job.company}, <span class="font-normal text-gray-400">{job.location}</span></h3>
            <span class="text-xs text-gray-500">{job.period}</span>
          </div>
          <p class="text-gray-300 italic mb-3">{job.role}</p>
          {"description" in job && job.description && (
            <p class="text-sm text-gray-400 mb-3">{job.description}</p>
          )}
          <ul class="space-y-2 text-sm text-gray-400 list-disc list-inside">
            {job.bullets.map((bullet) => (
              <li set:html={bullet} />
            ))}
          </ul>
        </div>
      ))}
    </section>
  </div>

  <!-- Sidebar -->
  <aside class="space-y-8">
    <!-- Contact -->
    <section>
      <h2 class="text-sm font-bold text-blue-500 uppercase tracking-wider mb-4">Contact</h2>
      <div class="space-y-1 text-sm text-gray-400">
        {data.header.contact.map((item) => (
          <p class="flex items-center gap-2">
            <i class={item.icon + " w-4"}></i>
            {item.href ? (
              <a href={item.href} class="text-blue-400 hover:underline" target={item.type !== "email" ? "_blank" : undefined} rel={item.type !== "email" ? "noopener noreferrer" : undefined}>
                {item.value}
              </a>
            ) : (
              <span>{item.value}</span>
            )}
          </p>
        ))}
      </div>
    </section>

    <!-- Skills -->
    <section>
      <h2 class="text-sm font-bold text-blue-500 uppercase tracking-wider mb-4">Skills</h2>
      
      <div class="space-y-4">
        {Object.entries(data.skills).map(([category, skills]) => (
          <div>
            <h4 class="text-sm font-bold text-white mb-1">{category}</h4>
            <p class="text-sm text-gray-400">{skills.join(", ")}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Education -->
    <section>
      <h2 class="text-sm font-bold text-blue-500 uppercase tracking-wider mb-4">Education</h2>
      
      <div>
        <h3 class="text-sm font-bold text-white">{data.education.institution}</h3>
        <p class="text-xs text-gray-500 mb-1">{data.education.period}</p>
        <p class="text-sm text-gray-400">{data.education.degree}</p>
      </div>
    </section>

    <!-- Languages -->
    <section>
      <h2 class="text-sm font-bold text-blue-500 uppercase tracking-wider mb-4">Languages</h2>
      
      <p class="text-sm text-gray-400">{data.languages.join(", ")}</p>
    </section>
  </aside>
</div>