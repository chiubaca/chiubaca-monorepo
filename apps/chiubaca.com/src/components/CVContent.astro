---
import { cvData } from "../data/cv";

interface Props {
  data?: typeof cvData;
}

const data = Astro.props.data || cvData;

const skillCategoryColors: Record<string, { bg: string; text: string; border: string; dot: string }> = {
  "Core Languages": {
    bg: "bg-violet-100 dark:bg-violet-900/30",
    text: "text-violet-800 dark:text-violet-200",
    border: "border-violet-200 dark:border-violet-700",
    dot: "bg-violet-500",
  },
  Frontend: {
    bg: "bg-blue-100 dark:bg-blue-900/30",
    text: "text-blue-800 dark:text-blue-200",
    border: "border-blue-200 dark:border-blue-700",
    dot: "bg-blue-500",
  },
  Backend: {
    bg: "bg-emerald-100 dark:bg-emerald-900/30",
    text: "text-emerald-800 dark:text-emerald-200",
    border: "border-emerald-200 dark:border-emerald-700",
    dot: "bg-emerald-500",
  },
  Tooling: {
    bg: "bg-gray-100 dark:bg-gray-700/50",
    text: "text-gray-800 dark:text-gray-200",
    border: "border-gray-200 dark:border-gray-600",
    dot: "bg-gray-500",
  },
};

const allSkills = Object.entries(data.skills).flatMap(([category, skills]) =>
  skills.map((skill) => ({ skill, category }))
);
---

<article class="space-y-8">
  <!-- Header: Name + Summary -->
  <header class="border-b border-gray-700 pb-6">
    <h1 class="text-4xl font-bold text-white mb-3">{data.header.name}</h1>
    <p class="text-lg text-gray-300 leading-relaxed">{data.header.summary}</p>
  </header>

  <!-- Contact Badges Row -->
  <section class="flex flex-wrap gap-2">
    <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-gray-800 dark:bg-gray-800 rounded-full text-sm text-gray-200 font-mono font-medium">
      <i class="fa-solid fa-location-dot w-4 text-center"></i>
      {data.header.location}
    </span>
    {data.header.contact.map((item) => (
      <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-gray-800 dark:bg-gray-800 rounded-full text-sm text-gray-200 font-mono font-medium">
        <i class={item.icon + " w-4 text-center"}></i>
        {item.href ? (
          <a href={item.href} class="text-blue-400 hover:underline" target={item.type === "linkedin" || item.type === "github" ? "_blank" : undefined} rel={item.type === "linkedin" || item.type === "github" ? "noopener noreferrer" : undefined}>
            {item.value}
          </a>
        ) : (
          <span>{item.value}</span>
        )}
      </span>
    ))}
  </section>

  <!-- Education & Languages Row -->
  <section class="flex flex-wrap gap-x-8 gap-y-2 text-sm text-gray-400">
    <div class="flex items-center gap-2">
      <i class="fa-solid fa-graduation-cap w-4 text-center"></i>
      <span>{data.education.institution}</span>
      <span class="text-gray-500 font-mono font-medium">{data.education.period}</span>
      <span class="text-gray-400">—</span>
      <span>{data.education.degree}</span>
    </div>
    <div class="flex items-center gap-2">
      <i class="fa-solid fa-globe w-4 text-center"></i>
      <span>{data.languages.join(", ")}</span>
    </div>
  </section>

  <!-- Skills Section -->
  <section>
    <h2 class="text-lg font-bold text-blue-500 uppercase tracking-wider mb-3">Skills</h2>
    <div class="flex flex-wrap gap-2 mb-3">
      {allSkills.map(({ skill, category }) => {
        const colors = skillCategoryColors[category] || skillCategoryColors.Tooling;
        return (
          <span class={`px-3 py-1 rounded-md text-sm font-medium border font-mono ${colors.bg} ${colors.text} ${colors.border}`}>
            {skill}
          </span>
        );
      })}
    </div>
    <!-- Color Key Legend -->
    <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500">
      {Object.entries(skillCategoryColors).map(([category, colors]) => (
        <span class="flex items-center gap-1.5">
          <span class={`w-2 h-2 rounded-full ${colors.dot}`}></span>
          {category}
        </span>
      ))}
    </div>
  </section>

  <!-- Experience -->
  <section>
    <h2 class="text-lg font-bold text-blue-500 uppercase tracking-wider mb-6">Experience</h2>
    
    {data.experience.map((job, index) => (
      <div class={`mb-6 ${index < data.experience.length - 1 ? 'border-b border-gray-800 pb-6' : ''}`}>
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-1 mb-2">
          <h3 class="text-base font-bold text-white">{job.company}, <span class="font-normal text-gray-400">{job.location}</span></h3>
          <span class="text-sm text-gray-500 font-mono font-medium">{job.period}</span>
        </div>
        <p class="text-base text-gray-300 italic mb-3 job-title">{job.role}</p>
        {"description" in job && job.description && (
          <p class="text-sm text-gray-400 mb-3">{job.description}</p>
        )}
        <ul class="space-y-2 text-base text-gray-400 list-disc list-inside">
          {job.bullets.map((bullet) => (
            <li set:html={bullet} />
          ))}
        </ul>
      </div>
    ))}
  </section>
</article>