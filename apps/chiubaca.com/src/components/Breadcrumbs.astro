---
type BreadCrumb = { href: string; label: string };

interface Props {
  breadcrumbs?: BreadCrumb[];
}

const { breadcrumbs } = Astro.props;
---

{
  breadcrumbs !== undefined && (
    <div class="terminal-path py-2 pl-5">
      <a href="/" class="terminal-prompt-home hover:opacity-75">
        <span class="terminal-prompt">chiubaca@chiubaca.com</span>
        <span class="terminal-colon">:</span>
        <span class="terminal-home">~</span>
      </a>
      {breadcrumbs.length > 0 && (
        <>
          {breadcrumbs.map((b) => (
            <>
              <span class="terminal-slash">/</span>
              <a href={b.href} class="terminal-path-dir hover:opacity-75">
                {b.label.length > 20 ? `${b.label.slice(0, 20)}...` : b.label}
              </a>
            </>
          ))}
        </>
      )}
      <span class="terminal-caret">❯</span>
    </div>
  )
}

<style>
  .terminal-path {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    gap: 0;
  }

  .terminal-prompt-home {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    gap: 0;
  }

  .terminal-prompt {
    color: var(--accent-blue);
    font-weight: 500;
  }

  .terminal-colon {
    color: var(--text-muted);
  }

  .terminal-home {
    color: var(--accent-amber-bright);
  }

  .terminal-path-dir {
    color: var(--accent-amber-bright);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .terminal-slash {
    color: var(--text-muted);
    margin: 0 0.15em;
  }

  .terminal-caret {
    color: var(--accent-blue);
    margin-left: 0.5em;
  }
</style>
