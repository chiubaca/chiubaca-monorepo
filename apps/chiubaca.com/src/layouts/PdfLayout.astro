---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/src/styles/global.css">
  <style is:global>
    /* PDF-specific light theme overrides */
    body {
      background: white !important;
      color: black !important;
      font-family: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.4;
    }
    
    /* Convert dark theme colors to light theme for PDF */
    .text-white {
      color: black !important;
    }
    
    .text-gray-400 {
      color: #333 !important;
    }
    
    .text-gray-500 {
      color: #666 !important;
    }
    
    .text-gray-300 {
      color: #444 !important;
    }
    
    .text-blue-400,
    .text-blue-500 {
      color: #0066cc !important;
    }
    
    .border-gray-700 {
      border-color: #000 !important;
    }
    
    /* Ensure proper spacing */
    main {
      padding: 40px;
      max-width: 800px;
      margin: 0 auto;
    }
    
    /* Header styling */
    header {
      border-bottom: 2px solid #000 !important;
      padding-bottom: 20px !important;
      margin-bottom: 30px !important;
    }
    
    h1 {
      font-size: 28pt;
      font-weight: 700;
      color: black !important;
      margin-bottom: 8px;
    }
    
    /* Section headers */
    h2 {
      font-size: 11pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: black !important;
      border-bottom: 2px solid #000;
      padding-bottom: 5px;
      margin-bottom: 15px;
      margin-top: 25px;
    }
    
    h2:first-child {
      margin-top: 0;
    }
    
    h3 {
      font-size: 11pt;
      font-weight: 600;
      color: black !important;
    }
    
    h4 {
      font-size: 10pt;
      font-weight: 600;
      color: black !important;
    }
    
    /* Grid layout for PDF */
    .grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 40px;
    }
    
    /* Contact section */
    .space-y-1 > * + * {
      margin-top: 4px;
    }
    
    aside section {
      margin-bottom: 20px;
    }
    
    /* Ensure icons are properly styled */
    i {
      color: #333 !important;
      width: 16px;
      text-align: center;
    }
    
    /* Links */
    a {
      color: #0066cc !important;
      text-decoration: none;
    }
    
    a:hover {
      text-decoration: underline;
    }
    
    /* Print optimizations */
    @media print {
      body {
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
      }
    }
  </style>
</head>
<body>
  <main>
    <slot />
  </main>
</body>
</html>