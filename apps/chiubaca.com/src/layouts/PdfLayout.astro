---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/src/styles/global.css">
  <style is:global>
    /* PDF-specific light theme */
    body {
      background: white !important;
      color: #1a1a1a !important;
      font-family: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.5;
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }

    main {
      padding: 40px;
      max-width: 800px;
      margin: 0 auto;
    }

    /* Header */
    header {
      border-bottom: 2px solid #1a1a1a !important;
      padding-bottom: 20px !important;
      margin-bottom: 24px !important;
    }

    h1 {
      font-size: 24pt;
      font-weight: 700;
      color: #1a1a1a !important;
      margin-bottom: 8px;
    }

    /* Contact badges */
    section:first-of-type {
      margin-bottom: 24px;
    }

    section:first-of-type span {
      background: #f3f4f6 !important;
      color: #374151 !important;
    }

    section:first-of-type a {
      color: #0066cc !important;
    }

    /* Section headers */
    h2 {
      font-size: 10pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #1a1a1a !important;
      border-bottom: 1px solid #d1d5db;
      padding-bottom: 4px;
      margin-bottom: 12px;
      margin-top: 20px;
    }

    h2:first-of-type {
      margin-top: 0;
    }

    h3 {
      font-size: 11pt;
      font-weight: 600;
      color: #1a1a1a !important;
    }

    /* Skill tags - category colors */
    .bg-violet-100, .bg-violet-900\/30 {
      background: #ede9fe !important;
    }
    .text-violet-800, .text-violet-200 {
      color: #6d28d9 !important;
    }
    .border-violet-200, .border-violet-700 {
      border-color: #c4b5fd !important;
    }

    .bg-blue-100, .bg-blue-900\/30 {
      background: #dbeafe !important;
    }
    .text-blue-800, .text-blue-200 {
      color: #1d4ed8 !important;
    }
    .border-blue-200, .border-blue-700 {
      border-color: #93c5fd !important;
    }

    .bg-emerald-100, .bg-emerald-900\/30 {
      background: #d1fae5 !important;
    }
    .text-emerald-800, .text-emerald-200 {
      color: #047857 !important;
    }
    .border-emerald-200, .border-emerald-700 {
      border-color: #6ee7b7 !important;
    }

    .bg-gray-100, .bg-gray-700\/50 {
      background: #e5e7eb !important;
    }
    .text-gray-800, .text-gray-200 {
      color: #374151 !important;
    }
    .border-gray-200, .border-gray-600 {
      border-color: #d1d5db !important;
    }

    /* Icon colors */
    i {
      color: #374151 !important;
    }

    /* Text overrides */
    .text-gray-300, .text-gray-400 {
      color: #4b5563 !important;
    }

    .text-gray-500 {
      color: #6b7280 !important;
    }

    /* Links */
    a {
      color: #0066cc !important;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    /* Experience section */
    .border-gray-800 {
      border-color: #d1d5db !important;
    }

    /* Page break handling */
    section, article > div {
      break-inside: avoid;
    }

    @media print {
      body {
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
      }
    }
  </style>
</head>
<body>
  <main>
    <slot />
  </main>
</body>
</html>