{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chiubaca-com",
  "compatibility_date": "2026-05-06",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
  },
  "routes": [
    {
      "pattern": "chiubaca.com",
      "custom_domain": true,
    },
  ],
  "browser": {
    "binding": "BROWSER",
  },
}
